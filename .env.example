# =============================================================================
# BCHAT Environment Variables
# =============================================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# REQUIRED - Core API
# =============================================================================

# OpenRouter API key for LLM chat functionality
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# =============================================================================
# OPTIONAL - LLM Configuration
# =============================================================================

# Default LLM model for chat responses
# See available models: https://openrouter.ai/models
LLM_MODEL=openai/gpt-4o-mini

# LLM model for reasoning tasks (Generate KB/Policy)
# Requires a model with strong reasoning capabilities
LLM_MODEL_REASONING=google/gemini-2.5-pro

# =============================================================================
# SECURITY - Encryption
# =============================================================================

# Master key for encrypting tenant API keys (AES-256)
# Required if you want to store tenant-specific API keys in the database
# Generate with: uuidgen or openssl rand -hex 16
# WARNING: If you lose this key, encrypted API keys cannot be recovered!
ENCRYPTION_MASTER_KEY=

# =============================================================================
# RAG Pipeline (Optional)
# =============================================================================

# Enable RAG (Retrieval-Augmented Generation) pipeline
# Values: true | false
RAG_PIPELINE_ENABLED=false

# Embedding provider for vector search
# Values: openrouter | mock | local
EMBEDDING_PROVIDER=openrouter

# Embedding model (when using openrouter provider)
EMBEDDING_MODEL=openai/text-embedding-3-small

# LanceDB storage provider
# Values: memory | local | s3
# - memory: In-memory (lost on restart, testing only)
# - local: Local filesystem (development)
# - s3: S3-compatible storage (production, e.g., Tigrisdata)
LANCEDB_STORAGE_PROVIDER=local

# Local LanceDB path (when LANCEDB_STORAGE_PROVIDER=local)
# LANCEDB_LOCAL_PATH=./build/data/lancedb

# Enable LLM verifier for response validation (optional safety net)
LLM_VERIFIER_ENABLED=false

# =============================================================================
# S3/Tigrisdata (Production only)
# =============================================================================
# Only needed when LANCEDB_STORAGE_PROVIDER=s3

# Tigrisdata credentials (fly.io integrated storage)
# Format: tid_xxxxx for access key, tsec_xxxxx for secret
# AWS_ACCESS_KEY_ID=tid_xxxxx
# AWS_SECRET_ACCESS_KEY=tsec_xxxxx

# S3 bucket name
# LANCEDB_S3_BUCKET=your-bucket-name

# S3 endpoint (Tigrisdata on fly.io)
# LANCEDB_S3_ENDPOINT=fly.storage.tigris.dev

# S3 region
# LANCEDB_S3_REGION=auto

# =============================================================================
# Server Configuration
# =============================================================================

# Server mode: dev | prod | demo
# MEMOS_MODE=dev

# Server port
# MEMOS_PORT=5230

# Data directory path
# MEMOS_DATA=/var/opt/memos

# Database connection string (SQLite default)
# MEMOS_DSN=

# =============================================================================
# Usage Examples
# =============================================================================
#
# Local Development:
#   1. cp .env.example .env
#   2. Edit .env with your values
#   3. task run:rag
#
# Docker:
#   docker run --env-file .env -p 5230:5230 bchat
#
# Fly.io (use fly secrets instead):
#   fly secrets set OPENROUTER_API_KEY=sk-or-v1-xxx
#   fly secrets set ENCRYPTION_MASTER_KEY=$(uuidgen)
#   fly deploy
