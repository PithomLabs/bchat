# =============================================================================
# Multi-stage Dockerfile for fly.io deployment with LanceDB RAG support
# =============================================================================

# Stage 1: Build frontend and widget
FROM node:20-alpine AS frontend

# Build main frontend
WORKDIR /frontend-build
COPY web/package*.json ./
RUN npm ci
COPY web/ .
RUN npm run release

# Build widget
WORKDIR /widget-build
COPY widget/package*.json ./
RUN npm ci
COPY widget/ .
RUN npm run build

# Stage 2: Build backend with LanceDB CGO support
FROM golang:1.24 AS backend
WORKDIR /backend-build

# Install build dependencies for CGO
RUN apt-get update && apt-get install -y \
    gcc \
    libc-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy LanceDB native libraries and headers
COPY lib/linux_amd64/ /usr/local/lib/lancedb/
COPY include/ /usr/local/include/lancedb/

# Copy go modules first for better layer caching
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY . .

# Copy frontend build from stage 1
COPY --from=frontend /server/router/frontend/dist ./server/router/frontend/dist

# Build with LanceDB RAG support
ENV CGO_ENABLED=1
ENV CGO_CFLAGS="-I/usr/local/include/lancedb"
ENV CGO_LDFLAGS="-L/usr/local/lib/lancedb -llancedb_go -Wl,-rpath,/usr/local/lib/lancedb"

RUN go build -tags rag -ldflags="-s -w" -o memos ./bin/memos/main.go

# Stage 3: Minimal runtime image
FROM debian:bookworm-slim

WORKDIR /usr/local/memos

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    tzdata \
    && rm -rf /var/lib/apt/lists/*

# Copy LanceDB shared library for runtime
COPY --from=backend /usr/local/lib/lancedb/liblancedb_go.so /usr/local/lib/
RUN ldconfig

# Copy application binary and scripts
COPY --from=backend /backend-build/memos .
COPY scripts/entrypoint.sh .
RUN chmod +x entrypoint.sh

# Copy widget bundle for external embeds
COPY --from=frontend /widget-build/dist ./widget/dist

# Create data directory for SQLite and local storage
RUN mkdir -p /var/opt/memos
VOLUME /var/opt/memos

# Environment defaults
ENV TZ="UTC"
ENV MEMOS_MODE="prod"
ENV MEMOS_PORT="5230"

ENV LLM_MODEL_REASONING="nvidia/nemotron-3-super-120b-a12b:free"

# RAG pipeline configuration (Tigrisdata S3 + OpenRouter)
ENV RAG_PIPELINE_ENABLED="true"
ENV LANCEDB_STORAGE_PROVIDER="s3"
ENV LANCEDB_S3_ENDPOINT="fly.storage.tigris.dev"
ENV LANCEDB_S3_REGION="auto"
ENV EMBEDDING_PROVIDER="openrouter"
ENV EMBEDDING_MODEL="openai/text-embedding-3-small"
ENV EMBEDDING_BATCH_SIZE=10


# Optional LLM verifier (disabled by default)
ENV LLM_VERIFIER_ENABLED="false"

EXPOSE 5230

ENTRYPOINT ["./entrypoint.sh", "./memos"]
